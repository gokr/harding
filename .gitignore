# Nim build artifacts
nimcache/
*.exe
*.dll
*.so
*.dylib

# Generated files
build/
*.o
*.obj
*.ilk
*.pdb
*.exp
*.lib

# IDE files
# .vscode/ is kept for repository-level language support
.vscode/settings.json.user
.vscode/tasks.json
.vscode/launch.json
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Local configuration
.claude/

# Temporary files
*.tmp
*.temp
workspace-*.hrd

# Test outputs
*.out
testresults/

# Harding binaries (specific names and all variants)
/harding
/harding_*
/hardingf
/harding-lsp
/granite
/bona
/mi

# Profiling and benchmark output
/profile_results.txt

# Binary patterns from source directories
# Ignore compiled binaries (no extension) but keep source files
src/harding/compiler/*
!src/harding/compiler/*.nim
src/harding/repl/*
!src/harding/repl/*.nim
src/harding/codegen/*
!src/harding/codegen/*.nim
src/harding/parser/*
!src/harding/parser/*.nim

# Test compiled binaries (no extension) - keep .nim source files
tests/*
!tests/*.nim
!tests/*.hrd
examples/test_*

# Root-level temporary test binaries
/test_*
!/test_*.nim

# Nimble files
nimble.develop
nimble.paths
nimbledeps

# VSCode extension build artifacts
vscode-harding/node_modules/
vscode-harding/out/
vscode-harding/package-lock.json
*.vsix

# External libraries (user-installed)
# Keep the directory and README, but ignore installed libraries
external/*
!external/.gitkeep
!external/README.md

# Cached registry metadata
registry-full.json

# Machine-local external library integration output
src/harding/external/external_libs_generated.nim
src/harding/external/generator

# SQLite databases
*.db
badminton-buddy/badminton.db
