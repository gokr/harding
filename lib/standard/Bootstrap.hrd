#!/usr/bin/env harding
#
# Bootstrap.hrd - Loads the standard library

Standard := Library new.
Standard name: "Standard".
Harding at: "StandardLibrary" put: Standard.

Standard load: "lib/standard/SortedCollection.hrd"
Standard load: "lib/standard/Interval.hrd"
Standard load: "lib/standard/File.hrd"
Standard load: "lib/standard/FileStream.hrd"
Standard load: "lib/standard/TestCase.hrd"

Harding import: Standard.
