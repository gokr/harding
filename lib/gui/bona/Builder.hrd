# ============================================================================.
# Builder - Granite Application Builder for Bona IDE.
# ============================================================================.
#
# A GUI tool for creating, editing, and compiling Harding Applications.
# using the Granite compiler. All work is captured in Application subclasses.
# and auto-saved to .hrd files like the Browser.

Builder := Object derive: #(model, owner, window, appList, appEditor, outputView)
# Builder implements Bona's Granite application builder and starter-template workflow.
# It discovers Application subclasses, edits main: methods, and triggers Granite builds.
# Sample app creation, build output, and app selection behavior all flow through this class.
# Keep app-builder orchestration here so Granite and Browser stay loosely coupled.
# This file is the IDE surface for turning Harding applications into runnable programs.
# Changes here affect both template generation and build-time developer experience.

Builder>>initialize [
  model := BuilderModel new
  ^ self
]

Builder class>>open [
  | builder |
  builder := Builder new
  builder openInstance
  ^ builder
]

Builder class>>openFor: anOwner [
  | builder |
  builder := Builder new
  builder owner: anOwner
  builder openInstance
  ^ builder
]

Builder>>owner: anOwner [
  owner := anOwner
]

Builder>>openInstance [
  | mainBox headerBar contentBox leftPane rightPane paned |
  
  # Create window
  window := GtkWindow new
  window title: "Application Builder"
  window setDefaultSize: 900 height: 600
  window onClose: [ self onClose ]

  # Main layout
  mainBox := GtkBox vertical
  mainBox setSpacing: 0
  mainBox marginStart: 5
  mainBox marginEnd: 5
  mainBox marginTop: 5
  mainBox marginBottom: 5

  # Header bar with buttons
  headerBar := self createHeaderBar
  mainBox append: headerBar

  # Content area with paned layout
  contentBox := GtkBox vertical
  contentBox vexpand: true
  contentBox setSpacing: 5
  contentBox marginStart: 5
  contentBox marginEnd: 5
  contentBox marginTop: 5
  contentBox marginBottom: 5

  paned := GtkPaned horizontal
  paned vexpand: true

  # Left pane: Application list
  leftPane := self createAppListPane
  paned setStartChild: leftPane

  # Right pane: Editor and build output
  rightPane := self createEditorPane
  paned setEndChild: rightPane

  contentBox append: paned
  mainBox append: contentBox

  window setChild: mainBox

  # Register with owner
  owner notNil ifTrue: [ owner addWindow: window ]

  window present

  # Populate application list after window is visible
  [ self refreshAppList ] on: Exception do: [:ex |
    Transcript showCr: ("Builder refresh failed: " & ex printString)
  ]

  Transcript showCr: "Application Builder opened"
  ^ self
]

Builder>>createHeaderBar [
  | headerBar newButton buildButton runButton refreshButton spacer |

  headerBar := GtkBox horizontal
  headerBar setSpacing: 0
  headerBar vexpand: false

  # New Application button
  newButton := GtkButton new
  newButton label: "New" iconName: "document-new"
  newButton tooltip: "Create new Application subclass"
  newButton clicked: [ self createNewApp ]
  headerBar append: newButton

  spacer := GtkLabel new: "  "
  headerBar append: spacer

  # Refresh button
  refreshButton := GtkButton new
  refreshButton label: "Refresh" iconName: "view-refresh"
  refreshButton tooltip: "Refresh application list"
  refreshButton clicked: [ self refreshAppList ]
  headerBar append: refreshButton

  spacer := GtkLabel new: ""
  spacer vexpand: false
  spacer hexpand: true
  headerBar append: spacer

  # Build button
  buildButton := GtkButton new
  buildButton label: "Build" iconName: "system-run"
  buildButton tooltip: "Compile selected Application to binary"
  buildButton clicked: [ self buildCurrentApp ]
  headerBar append: buildButton

  spacer := GtkLabel new: "  "
  headerBar append: spacer

  # Run button
  runButton := GtkButton new
  runButton label: "Run" iconName: "media-playback-start"
  runButton tooltip: "Run the built binary"
  runButton clicked: [ self runCurrentApp ]
  headerBar append: runButton

  ^ headerBar
]

Builder>>createAppListPane [
  | box label scroll |

  box := GtkBox vertical
  box setSpacing: 5
  box hexpand: false
  box vexpand: true
  box setSizeRequest: 200 height: -1

  label := GtkLabel new: "Applications"
  label setHalignStart
  box append: label

  # Create list box for applications
  appList := GtkListBox new
  appList vexpand: true
  appList onRowSelected: [ :index | self onAppSelected: index ]

  scroll := GtkScrolledWindow new
  scroll vexpand: true
  scroll setChild: appList

  box append: scroll

  ^ box
]

Builder>>addTemplateButtons: box [
  | button |

  # HelloWorld template
  button := GtkButton newLabel: "HelloWorld"
  button tooltip: "Create HelloWorld application"
  button clicked: [ self createTemplateApp: #HelloWorld ]
  box append: button

  # SimpleGUI template
  button := GtkButton newLabel: "SimpleGUI"
  button tooltip: "Create GUI application with window"
  button clicked: [ self createTemplateApp: #SimpleGUI ]
  box append: button

  # CounterApp template
  button := GtkButton newLabel: "CounterApp"
  button tooltip: "Create counter application"
  button clicked: [ self createTemplateApp: #CounterApp ]
  box append: button
]

Builder>>createEditorPane [
  | box label scroll |

  box := GtkBox vertical
  box setSpacing: 5
  box vexpand: true

  # Application name field
  label := GtkLabel new: "Application: (none selected)"
  label setHalignStart
  box append: label

  # Libraries section (simplified - shown as label for now)
  label := GtkLabel new: "Libraries: Core, Standard"
  label setHalignStart
  label marginTop: 5
  box append: label

  # Main method editor
  label := GtkLabel new: "main: method:"
  label setHalignStart
  label marginTop: 10
  box append: label

  appEditor := GtkSourceView new
  appEditor showLineNumbers: true
  appEditor setTabWidth: 2
  appEditor vexpand: true

  scroll := GtkScrolledWindow new
  scroll vexpand: true
  scroll setChild: appEditor

  box append: scroll

  # Build output
  label := GtkLabel new: "Build Output:"
  label setHalignStart
  label marginTop: 10
  box append: label

  outputView := GtkTextView new
  outputView vexpand: false
  outputView setSizeRequest: -1 height: 100
  outputView editable: false

  scroll := GtkScrolledWindow new
  scroll vexpand: false
  scroll setSizeRequest: -1 height: 100
  scroll setChild: outputView

  box append: scroll

  ^ box
]

