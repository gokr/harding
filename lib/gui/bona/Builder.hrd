Builder>>addAppRow: appClass [
  # Helper method to add a row label to the list box
  | label appName |
  appName := self appDisplayName: appClass
  label := GtkLabel new: appName
  label setHalignStart
  appList append: label
]

Builder>>addEmptyRow [
  # Helper method to add empty row label
  | label |
  label := GtkLabel new: "(no applications found)"
  label setHalignStart
  appList append: label
]

Builder>>refreshAppList [
  | apps index |

  model isRefreshing: true
  [
    # Clear existing items
    appList clear

    # Find all Application subclasses
    apps := self findApplicationSubclasses
    model appClasses: apps

    apps isEmpty
      ifTrue: [
        self addEmptyRow
      ]
      ifFalse: [
        index := 0
        [ index < apps size ] whileTrue: [
          self addAppRow: (apps at: index)
          index := index + 1
        ]
      ]

    Transcript showCr: ("Found " & (apps size printString) & " applications")
  ] on: Exception do: [:ex |
    Transcript showCr: ("Builder refresh failed: " & ex printString)
  ]

  model isRefreshing: false
  ^ self
]

Builder>>appDisplayName: appClass [
  ^ model appDisplayName: appClass
]

Builder>>isApplicationSubclass: aClass [
  ^ model isApplicationSubclass: aClass
]

Builder>>findApplicationSubclasses [
  ^ model findApplicationSubclasses
]

Builder>>onAppSelected: index [
  | appClass |

  (model isRefreshing) ifTrue: [ ^ self ]
  index isNil ifTrue: [ ^ self ]
  (index isKindOf: Integer) ifFalse: [ ^ self ]
  index < 0 ifTrue: [ ^ self ]

  ((model appClasses) isNil or: [ index >= ((model appClasses) size) ]) ifTrue: [ ^ self ]

  appClass := (model appClasses) at: index
  appClass isNil ifTrue: [
    self showOutput: "Error: Could not find selected application class"
    ^ self
  ]

  model currentApp: appClass
  self loadApp: appClass
]

Builder>>loadApp: appClass [
  | source libraries appName |

  appName := self appDisplayName: appClass

  # Update window title
  window title: ("Application Builder - " & appName)

  # Method source extraction is currently placeholder-based
  # appClass methods returns an Array of selectors, not a method table
  source := self defaultMainSource

  appEditor text: source

  # Set library checkboxes
  libraries := self getLibrariesFor: appClass
  self setLibraryCheckboxes: libraries

  Transcript showCr: ("Loaded application: " & appName)
]

Builder>>getLibrariesFor: appClass [
  # Library checkboxes are currently disabled in the UI
  # Keep this method side-effect free to avoid callback-time instantiation issues
  ^ Array new
]

Builder>>setLibraryCheckboxes: libraries [
  # This would iterate through checkboxes and set their state
  # based on the libraries array
]

Builder>>defaultMainSource [
  ^ "main: args [
  Transcript showCr: 'Hello from Granite!'
  ^ 0
]"
]

Builder>>methodSource: method [
  # This would extract the source code from the method
  # For now, return a placeholder
  ^ self defaultMainSource
]

Builder>>buildCurrentApp [
  | result output appName |

  (model currentApp) isNil ifTrue: [
    self showOutput: "Error: No application selected"
    ^ self
  ]

  appName := self appDisplayName: (model currentApp)
  self showOutput: ("Building " & appName & "...")

  # Save current edits first
  self saveCurrentApp

  # Call Granite build
  result := [ Granite build: ((model currentApp) new) ] on: Exception do: [:ex |
    "Error: " & ex printString & " (Granite build primitive may be unavailable in this bona build)"
  ]

  output := (result class name = "String")
    ifTrue: [ result ]
    ifFalse: [ "Build completed" ]

  self showOutput: output
]

Builder>>saveCurrentApp [
  | source libraries appName |

  (model currentApp) isNil ifTrue: [ ^ self ]

  # Get source from editor
  source := appEditor text

  # Get selected libraries
  libraries := self getSelectedLibraries

  # Compile and install new method
  self compileMethod: source for: (model currentApp)

  # Save libraries preference
  self saveLibraries: libraries for: (model currentApp)

  appName := self appDisplayName: (model currentApp)
  Transcript showCr: ("Saved " & appName)
]

Builder>>getSelectedLibraries [
  | result |
  result := Array new
  # This would iterate through checkboxes and collect selected ones
  ^ result
]

Builder>>saveLibraries: libraries for: appClass [
  # Save libraries to application instance
  # This would be stored in the application's libraries slot
]

Builder>>compileMethod: source for: appClass [
  | fullSource appName |

  appName := self appDisplayName: appClass

  # Normalize editor text to a full class method definition
  fullSource := (source includesSubString: ">>")
    ifTrue: [ source ]
    ifFalse: [
      (source startsWith: "main:")
        ifTrue: [ appName & ">>" & source ]
        ifFalse: [ appName & ">>main: args [" & source & "]" ]
    ]

  # Compile and install in interpreter mode
  [ Object eval: fullSource ] on: Exception do: [:ex |
    self showOutput: ("Error compiling method: " & ex printString)
  ]
]

Builder>>runCurrentApp [
  | binaryPath cmd appName |

  (model currentApp) isNil ifTrue: [
    self showOutput: "Error: No application selected"
    ^ self
  ]

  appName := self appDisplayName: (model currentApp)
  binaryPath := "./build/" & appName

  self showOutput: ("Running: " & binaryPath)

  # Run the binary
  cmd := binaryPath & " &"
  System perform: cmd
]

Builder>>createNewApp [
  | name appClass source idx found |

  Transcript showCr: "Builder: creating new application"
  self showOutput: "Creating new application..."

  # Simple dialog to get application name
  # In a real implementation, this would show a proper dialog
  name := self uniqueAppName: "MyApp"

  # Check if class already exists
  ((Harding at: name ifAbsent: [ nil ]) notNil) ifTrue: [
    self showOutput: ("Error: Class " & name & " already exists")
    ^ self
  ]

  # Create the Application subclass
  source := name & " := Application derive: #()

" & name & ">>main: args [
  Transcript showCr: \"Hello from " & name & "!\"
  ^ 0
]
"

  # Compile and install the class
  appClass := [ Object eval: source ] on: Exception do: [:ex |
    self showOutput: ("Error creating application: " & ex printString)
    ^ self
  ]

  (appClass isClass) ifFalse: [
    appClass := Harding at: name ifAbsent: [ nil ]
  ]

  appClass notNil ifTrue: [
    Harding at: name put: appClass
  ]

  # Refresh the list
  self refreshAppList

  # Select the new app
  appClass := Harding at: name ifAbsent: [ appClass ]
  appClass isNil ifTrue: [
    self showOutput: ("Error: Created source but class not registered: " & name)
    ^ self
  ]

  model currentApp: appClass

  # Select the new app in the list when possible
  idx := 0
  found := false
  [ (idx < ((model appClasses) size)) and: [ found not ] ] whileTrue: [
    (((model appClasses) at: idx) == appClass) ifTrue: [
      appList selectIndex: idx
      found := true
    ] ifFalse: [
      idx := idx + 1
    ]
  ]

  [ self loadApp: appClass ] on: Exception do: [:ex |
    self showOutput: ("Created app but failed to load editor: " & ex printString)
  ]

  self showOutput: ("Created new application: " & name)
  Transcript showCr: ("Builder: created new application " & name)
]

Builder>>createTemplateApp: templateName [
  | name |
  name := templateName asString
  name = "HelloWorld" ifTrue: [ ^ self createHelloWorldApp ]
  name = "SimpleGUI" ifTrue: [ ^ self createSimpleGUIApp ]
  name = "CounterApp" ifTrue: [ ^ self createCounterApp ]
  self showOutput: ("Unknown template: " & name)
  ^ self
]

Builder>>createHelloWorldApp [
  | name source appClass |

  name := self uniqueAppName: "HelloWorld"

  source := name & " := Application derive: #()

" & name & ">>main: args [
  Transcript showCr: \"Hello, World!\"
  args size > 0 ifTrue: [
    Transcript showCr: (\"Arguments: \" & (args printString))
  ]
  ^ 0
]
"

  appClass := [ Object eval: source ] on: Exception do: [:ex |
    self showOutput: ("Error creating template: " & ex printString)
    ^ self
  ]

  (appClass isClass) ifFalse: [
    appClass := Harding at: name ifAbsent: [ nil ]
  ]

  appClass notNil ifTrue: [
    Harding at: name put: appClass
  ]

  self refreshAppList

  appClass := Harding at: name ifAbsent: [ appClass ]
  model currentApp: appClass
  [ self loadApp: appClass ] on: Exception do: [:ex |
    self showOutput: ("Created template but failed to load editor: " & ex printString)
  ]

  self showOutput: ("Created HelloWorld application: " & name)
]

Builder>>createSimpleGUIApp [
  | name source appClass |

  name := self uniqueAppName: "SimpleGUI"

  source := name & " := Application derive: #()

" & name & ">>main: args [
  | window button |
  window := GtkWindow new
  window title: \"" & name & "\"
  window setDefaultSize: 400 height: 300

  button := GtkButton newLabel: \"Click Me!\"
  button clicked: [ Transcript showCr: \"Button clicked!\" ]

  window setChild: button
  window present

  # Start GTK main loop
  GtkWidget main
  ^ 0
]
"

  appClass := [ Object eval: source ] on: Exception do: [:ex |
    self showOutput: ("Error creating template: " & ex printString)
    ^ self
  ]

  (appClass isClass) ifFalse: [
    appClass := Harding at: name ifAbsent: [ nil ]
  ]

  appClass notNil ifTrue: [
    Harding at: name put: appClass
  ]

  self refreshAppList

  appClass := Harding at: name ifAbsent: [ appClass ]
  model currentApp: appClass
  [ self loadApp: appClass ] on: Exception do: [:ex |
    self showOutput: ("Created template but failed to load editor: " & ex printString)
  ]

  self showOutput: ("Created SimpleGUI application: " & name)
]

Builder>>createCounterApp [
  | name source appClass |

  name := self uniqueAppName: "CounterApp"

  source := name & " := Application derive: #(count)

" & name & ">>initialize [
  super initialize
  count := 0
]

" & name & ">>main: args [
  | window label incrementButton |
  window := GtkWindow new
  window title: \"Counter Application\"
  window setDefaultSize: 300 height: 200

  label := GtkLabel new: \"Count: 0\"

  incrementButton := GtkButton newLabel: \"Increment\"
  incrementButton clicked: [
    count := count + 1
    label label: (\"Count: \" & (count printString))
  ]

  window setChild: label
  window present

  GtkWidget main
  ^ 0
]
"

  appClass := [ Object eval: source ] on: Exception do: [:ex |
    self showOutput: ("Error creating template: " & ex printString)
    ^ self
  ]

  (appClass isClass) ifFalse: [
    appClass := Harding at: name ifAbsent: [ nil ]
  ]

  appClass notNil ifTrue: [
    Harding at: name put: appClass
  ]

  self refreshAppList

  appClass := Harding at: name ifAbsent: [ appClass ]
  model currentApp: appClass
  [ self loadApp: appClass ] on: Exception do: [:ex |
    self showOutput: ("Created template but failed to load editor: " & ex printString)
  ]

  self showOutput: ("Created CounterApp application: " & name)
]

Builder>>uniqueAppName: baseName [
  ^ model uniqueAppName: baseName
]

Builder>>showOutput: text [
  | buffer |
  model appendOutput: text
  buffer := outputView buffer
  buffer append: text
  buffer append: "\n"
]

Builder>>onClose [
  # Save any pending changes
  self saveCurrentApp

  # Unregister from owner
  owner notNil ifTrue: [ owner removeWindow: window ]

  Transcript showCr: "Application Builder closed"
]
