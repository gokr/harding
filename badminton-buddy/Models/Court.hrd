# Court model for Badminton Buddy.

Court := Object derivePublic: #(id, name, location, latitude, longitude, amenities, active).

Court>>amenitiesList [
  | amens |
  amens := amenities.
  amens isNil ifTrue: [ ^ Array new ].
  ^ (amens split: ",") collect: [:each | each trim ]
].

Court>>locationText [
  ^ location ifNil: [ "" ]
].

Court>>hasCoordinates [
  ^ latitude notNil and: [ longitude notNil ]
].
